{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>bfra-me/renovate-config#5.1.0",
    "github>bfra-me/renovate-config:fro-bot.json5#5.1.0",
    "github>sanity-io/renovate-config:semantic-commit-type",
    "github>sanity-io/renovate-config:security",
    "github>sanity-io/renovate-config:lock-file-maintenance",
    ":assignAndReview(fro-bot)",
    ":disableRateLimiting"
  ],
  "lockFileMaintenance": {
    "dependencyDashboardApproval": false
  },
  "packageRules": [
    {
      "matchPackageNames": ["python"],
      "allowedVersions": "<=3.13"
    },
    {
      "description": "Group GitHub actions except for @bfra-me.",
      "matchDepTypes": ["action"],
      "matchPackageNames": ["!bfra-me/{/,}**"],
      "groupName": "GitHub Actions"
    },
    {
      "description": "Update my project dependencies without a minimum release age.",
      "matchPackageNames": [
        "@bfra.me/{/,}**",
        "bfra-me/{/,}**",
        "/^@?fro.bot/",
        "fro-bot/{/,}**",
        "pro-actions/{/,}**"
      ],
      "minimumReleaseAge": null,
      "prCreation": "immediate"
    },
    {
      "description": "Update my project dependencies without a minimum release age.",
      "matchSourceUrlPrefixes": ["https://github.com/bfra-me", "https://github.com/fro-bot"],
      "minimumReleaseAge": null,
      "prCreation": "immediate"
    },
    {
      "description": [
        "Automerge `minor` and `patch` update types of @bfra-me and @fro-bot packages (disable dashboard approval)."
      ],
      "matchPackageNames": ["@bfra.me/**", "bfra-me/**", "@fro-bot/**", "fro-bot/**"],
      "matchUpdateTypes": ["minor", "patch"],
      "addLabels": ["automerge"],
      "dependencyDashboardApproval": false,
      "automerge": true,
      "platformAutomerge": true,
      "prCreation": "immediate",
      "rebaseWhen": "behind-base-branch"
    }
  ],
  "rebaseWhen": "behind-base-branch"
}
